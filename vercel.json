{
  "rewrites": [
    { "source": "/salarie/auth/callback", "destination": "/portal.html" },
    { "source": "/salarie/(.*)",          "destination": "/portal.html" },
    { "source": "/salarie",               "destination": "/portal.html" },
    { "source": "/salarié",               "destination": "/portal.html" },
    { "source": "/aide",                  "destination": "/aide.html" },
    { "source": "/aide/(.*)",             "destination": "/aide.html" },
    { "source": "/auth/callback",         "destination": "/index.html" },
    { "source": "/sw.js",                 "destination": "/sw.js" },
    { "source": "/(.*)",                  "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" },
        { "key": "Cache-Control",          "value": "no-cache" }
      ]
    },
    {
      "source": "/portal.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
